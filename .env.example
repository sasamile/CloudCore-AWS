# Copia este archivo a .env y ajusta los valores para tu PC vieja
# cp .env.example .env

# Base de datos (contenedor postgres separado, datos persistentes)
POSTGRES_USER=zyncloud
POSTGRES_PASSWORD=cambia-esta-contrasena
POSTGRES_DB=zyncloud
DATABASE_URL=postgresql://zyncloud:cambia-esta-contrasena@localhost:5432/zyncloud

# Seguridad
JWT_SECRET=cambia-este-secreto-largo-y-aleatorio

# IP o hostname de la PC vieja (acceso desde la red local)
PUBLIC_HOST=192.168.1.100
FRONTEND_URL=http://192.168.1.100:3000
NEXT_PUBLIC_API_URL=http://192.168.1.100:4000
NEXT_PUBLIC_PUBLIC_HOST=192.168.1.100

# Puertos expuestos en el host (opcional)
WEB_PORT=3000
API_PORT=4000

# Imágenes pre-construidas en GHCR (deploy automático hace pull)
ZYNCLOUD_IMAGE=ghcr.io/sasamile/cloudcore-aws/app:latest
UBUNTU_BASE_IMAGE=ghcr.io/sasamile/cloudcore-aws/ubuntu-base:latest

# Routing: tunnel (Cloudflare) | port | nginx
ROUTING_MODE=tunnel
BASE_DOMAIN=suescun.sbs
TUNNEL_WEB_HOST=zyncloud.suescun.sbs
TUNNEL_API_HOST=apizyncloud.suescun.sbs
CLOUDFLARED_CONFIG_PATH=/etc/cloudflared/config.yml
CLOUDFLARE_TUNNEL_ID=a4891bee-85d0-440f-a821-9429cd435d78
CLOUDFLARE_TUNNEL_NAME=zyncloud
CLOUDFLARE_TUNNEL_CREDENTIALS=/home/alfred/.cloudflared/a4891bee-85d0-440f-a821-9429cd435d78.json
# Opcional: reinicio automático del túnel tras cada instancia (usa SSH al host)
# CLOUDFLARED_RESTART_CMD=ssh -i ./secrets/host_console_key -o StrictHostKeyChecking=no alfred@host.docker.internal sudo systemctl restart cloudflared

# Object storage local path
STORAGE_DIR=/var/lib/zyncloud/storage

# Consola del servidor (PC host completa, no instancias Docker)
HOST_CONSOLE_ENABLED=true
HOST_CONSOLE_MODE=ssh
HOST_CONSOLE_SSH_HOST=host.docker.internal
HOST_CONSOLE_SSH_PORT=22
HOST_CONSOLE_SSH_USER=zyncloud
HOST_CONSOLE_LABEL=ZynCloud Server
# La llave vive en ./secrets/host_console_key (montada en el contenedor)
# Generar llave: bash scripts/setup-host-console-ssh.sh
