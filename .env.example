# =============================================================================
# ZynCloud — copia a .env en la PC vieja: cp .env.example .env && nano .env
# =============================================================================
# GitHub repo → Settings → Variables (para el build en CI):
#   NEXT_PUBLIC_API_URL=https://apizyncloud.suescun.sbs
#   NEXT_PUBLIC_PUBLIC_HOST=zyncloud.suescun.sbs
# =============================================================================

# --- Base de datos ---
POSTGRES_USER=zyncloud
POSTGRES_PASSWORD=cambia-esta-contrasena-segura
POSTGRES_DB=zyncloud
# Solo dev local; en Docker compose la API usa db:5432 automáticamente
DATABASE_URL=postgresql://zyncloud:cambia-esta-contrasena-segura@localhost:5432/zyncloud

# --- Seguridad ---
JWT_SECRET=cambia-este-secreto-largo-y-aleatorio-minimo-32-chars

# --- URLs públicas (producción con Cloudflare Tunnel) ---
PUBLIC_HOST=zyncloud.suescun.sbs
FRONTEND_URL=https://zyncloud.suescun.sbs
NEXT_PUBLIC_API_URL=https://apizyncloud.suescun.sbs
NEXT_PUBLIC_PUBLIC_HOST=zyncloud.suescun.sbs

# --- Puertos en el host ---
WEB_PORT=3000
API_PORT=4000

# --- Imágenes Docker (deploy automático desde GitHub Actions) ---
ZYNCLOUD_IMAGE=ghcr.io/sasamile/cloudcore-aws/app:latest
UBUNTU_BASE_IMAGE=ghcr.io/sasamile/cloudcore-aws/ubuntu-base:latest

# =============================================================================
# CLOUDFLARE TUNNEL (obligatorio para dominios de clientes 24/7 automático)
# =============================================================================
# El token debe ser de la MISMA cuenta Cloudflare donde existe el túnel "zyncloud".
# Crear token: My Profile → API Tokens → Create → Custom
#   Permiso: Account → Cloudflare Tunnel → Edit
# Account ID: Cloudflare dashboard → barra lateral derecha (cuenta del túnel)
# Tunnel ID: Zero Trust → Networks → Tunnels → zyncloud → ID
#
# Clientes (dominio propio ej. vekino.site) solo ponen CNAME en SU Cloudflare:
#   Type: CNAME | Name: prueba | Target: {CLOUDFLARE_TUNNEL_ID}.cfargotunnel.com
# =============================================================================
ROUTING_MODE=tunnel
BASE_DOMAIN=suescun.sbs
TUNNEL_WEB_HOST=zyncloud.suescun.sbs
TUNNEL_API_HOST=apizyncloud.suescun.sbs

CLOUDFLARE_ACCOUNT_ID=tu-account-id-de-la-cuenta-del-tunel
CLOUDFLARE_API_TOKEN=tu-api-token-cloudflare-tunnel-edit
CLOUDFLARE_TUNNEL_ID=a4891bee-85d0-440f-a821-9429cd435d78
CLOUDFLARE_TUNNEL_NAME=zyncloud

# Archivo de config que escribe ZynCloud (montado en el contenedor)
CLOUDFLARED_CONFIG_PATH=/etc/cloudflared/config.yml
# Credenciales del conector cloudflared en el HOST (ruta real en la PC vieja)
CLOUDFLARE_TUNNEL_CREDENTIALS=/home/alfred/.cloudflared/a4891bee-85d0-440f-a821-9429cd435d78.json
# Carpeta .cloudflared del host montada en el contenedor (fallback DNS local)
CLOUDFLARE_TUNNEL_CREDENTIALS_DIR=/home/alfred/.cloudflared
CLOUDFLARED_BIN_HOST=/usr/bin/cloudflared

# Con CLOUDFLARE_API_TOKEN no hace falta reiniciar cloudflared manualmente.
# Fallback si no hay API token (opcional):
# TUNNEL_USE_SSH=true
# CLOUDFLARED_RESTART_CMD=ssh -i ./secrets/host_console_key -o StrictHostKeyChecking=no -o BatchMode=yes alfred@host.docker.internal sudo systemctl restart cloudflared

# =============================================================================
# Object Storage
# =============================================================================
STORAGE_DIR=/var/lib/zyncloud/storage

# =============================================================================
# Server Console (terminal web del host — opcional)
# =============================================================================
HOST_CONSOLE_ENABLED=true
HOST_CONSOLE_MODE=ssh
HOST_CONSOLE_SSH_HOST=host.docker.internal
HOST_CONSOLE_SSH_PORT=22
HOST_CONSOLE_SSH_USER=alfred
HOST_CONSOLE_LABEL=ZynCloud Server
TUNNEL_USE_SSH=true
# Generar llave SSH: bash scripts/setup-host-console-ssh.sh
# (crea ./secrets/host_console_key montada en el contenedor)
