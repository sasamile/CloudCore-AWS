# Copia este archivo a .env y ajusta los valores para tu PC vieja
# cp .env.example .env

# Base de datos (contenedor postgres separado, datos persistentes)
POSTGRES_USER=zyncloud
POSTGRES_PASSWORD=cambia-esta-contrasena
POSTGRES_DB=zyncloud
DATABASE_URL=postgresql://zyncloud:cambia-esta-contrasena@localhost:5432/zyncloud

# Seguridad
JWT_SECRET=cambia-este-secreto-largo-y-aleatorio

# IP o hostname de la PC vieja (acceso desde la red local)
PUBLIC_HOST=192.168.1.100
FRONTEND_URL=http://192.168.1.100:3000
NEXT_PUBLIC_API_URL=http://192.168.1.100:4000
NEXT_PUBLIC_PUBLIC_HOST=192.168.1.100

# Puertos expuestos en el host (opcional)
WEB_PORT=3000
API_PORT=4000

# Imágenes pre-construidas en GHCR (deploy automático hace pull)
ZYNCLOUD_IMAGE=ghcr.io/sasamile/cloudcore-aws/app:latest
UBUNTU_BASE_IMAGE=ghcr.io/sasamile/cloudcore-aws/ubuntu-base:latest
