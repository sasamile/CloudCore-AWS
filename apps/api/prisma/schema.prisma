generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String               @id @default(cuid())
  email        String               @unique
  password     String?
  name         String
  emailVerified Boolean             @default(false)
  picture      String?
  createdAt    DateTime             @default(now())
  // --- MFA / seguridad (ZynAuth) ---
  mfaEnabled   Boolean              @default(false)
  mfaSecretEnc String?              // TOTP secret cifrado
  mfaBackupCodes String?            // JSON de hashes de codigos de respaldo
  failedLoginAttempts Int           @default(0)
  lockedUntil  DateTime?
  instances    Instance[]
  domains      Domain[]
  sshKeys      SshKey[]
  buckets      StorageBucket[]
  integrations IntegrationAccount[]
  deployments  Deployment[]
  oauthClients OAuthClient[]
  authCodes    AuthCode[]
  refreshTokens OidcRefreshToken[]
}

/// App registrada que puede autenticar usuarios via ZynAuth (equivalente a un "App Client" de Cognito).
model OAuthClient {
  id              String    @id @default(cuid())
  clientId        String    @unique
  clientSecretEnc String?               // null = cliente publico (solo PKCE)
  name            String
  redirectUris    String                // JSON array de URIs permitidas
  postLogoutUris  String    @default("[]")
  allowedScopes   String    @default("openid profile email offline_access")
  grantTypes      String    @default("authorization_code,refresh_token")
  isPublic        Boolean   @default(false)
  requirePkce     Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  ownerId         String?
  owner           User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  authCodes       AuthCode[]
  refreshTokens   OidcRefreshToken[]

  @@index([ownerId])
}

/// Codigo de autorizacion de corta vida (flow authorization_code + PKCE).
model AuthCode {
  code                String   @id
  clientId            String
  redirectUri         String
  scope               String
  nonce               String?
  codeChallenge       String?
  codeChallengeMethod String?
  expiresAt           DateTime
  consumedAt          DateTime?
  createdAt           DateTime @default(now())
  userId              String
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  oauthClientId       String
  client              OAuthClient @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

/// Refresh token OIDC (rotacion). Se guarda solo el hash.
model OidcRefreshToken {
  id            String    @id @default(cuid())
  tokenHash     String    @unique
  scope         String
  expiresAt     DateTime
  revokedAt     DateTime?
  rotatedTo     String?               // id del token que lo reemplazo
  createdAt     DateTime  @default(now())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  oauthClientId String
  client        OAuthClient @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Par de claves RSA para firmar tokens (rotables). La privada se guarda cifrada.
model SigningKey {
  id            String   @id @default(cuid())
  kid           String   @unique
  publicJwk     String                // JWK publico (JSON) expuesto en /jwks.json
  privatePemEnc String                // clave privada PEM cifrada
  algorithm     String   @default("RS256")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model IntegrationAccount {
  id              String   @id @default(cuid())
  provider        String
  providerUserId  String
  username        String?
  email           String?
  accessTokenEnc  String
  refreshTokenEnc String?
  scope           String?
  metadata        String?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
}

model Deployment {
  id           String   @id @default(cuid())
  repoFullName String
  branch       String   @default("main")
  rootDir      String   @default(".")
  buildCommand String?
  startCommand String?
  status       String   @default("idle")
  lastLog      String?
  instanceId   String
  instance     Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SshKey {
  id            String     @id @default(cuid())
  name          String
  fingerprint   String
  publicKey     String
  privateKeyEnc String?
  createdAt     DateTime   @default(now())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  instances     Instance[]

  @@unique([userId, name])
}

model Instance {
  id          String   @id @default(cuid())
  name        String
  containerId String?  @unique
  imageTag    String   @default("zyncloud/ubuntu-base:latest")
  status      String   @default("stopped")
  memoryLimit Int      @default(512)
  cpuLimit    Float    @default(0.5)
  internalPort Int?
  httpPort    Int?
  sshPort     Int?
  ipAddress   String?
  sshKeyId    String?
  sshKey      SshKey?  @relation(fields: [sshKeyId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  domains     Domain[]
  backups     Backup[]
  deployments Deployment[]
}

model Domain {
  id          String   @id @default(cuid())
  domain      String   @unique
  targetPort  Int
  sslEnabled  Boolean  @default(false)
  nginxConfig String?
  createdAt   DateTime @default(now())
  instanceId  String
  instance    Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Backup {
  id         String   @id @default(cuid())
  fileName   String
  filePath   String
  fileSize   Int
  createdAt  DateTime @default(now())
  instanceId String
  instance   Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model StorageBucket {
  id        String          @id @default(cuid())
  name      String
  createdAt DateTime        @default(now())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  objects   StorageObject[]

  @@unique([userId, name])
}

model StorageObject {
  id        String        @id @default(cuid())
  key       String
  size      Int
  mimeType  String?
  createdAt DateTime      @default(now())
  bucketId  String
  bucket    StorageBucket @relation(fields: [bucketId], references: [id], onDelete: Cascade)

  @@unique([bucketId, key])
}
