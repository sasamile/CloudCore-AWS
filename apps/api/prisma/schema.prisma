generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String               @id @default(cuid())
  email        String               @unique
  password     String?
  name         String
  createdAt    DateTime             @default(now())
  instances    Instance[]
  domains      Domain[]
  sshKeys      SshKey[]
  buckets      StorageBucket[]
  integrations IntegrationAccount[]
  deployments  Deployment[]
}

model IntegrationAccount {
  id              String   @id @default(cuid())
  provider        String
  providerUserId  String
  username        String?
  email           String?
  accessTokenEnc  String
  refreshTokenEnc String?
  scope           String?
  metadata        String?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
}

model Deployment {
  id           String   @id @default(cuid())
  repoFullName String
  branch       String   @default("main")
  rootDir      String   @default(".")
  buildCommand String?
  startCommand String?
  status       String   @default("idle")
  lastLog      String?
  instanceId   String
  instance     Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SshKey {
  id            String     @id @default(cuid())
  name          String
  fingerprint   String
  publicKey     String
  privateKeyEnc String?
  createdAt     DateTime   @default(now())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  instances     Instance[]

  @@unique([userId, name])
}

model Instance {
  id          String   @id @default(cuid())
  name        String
  containerId String?  @unique
  imageTag    String   @default("zyncloud/ubuntu-base:latest")
  status      String   @default("stopped")
  memoryLimit Int      @default(512)
  cpuLimit    Float    @default(0.5)
  internalPort Int?
  httpPort    Int?
  sshPort     Int?
  ipAddress   String?
  sshKeyId    String?
  sshKey      SshKey?  @relation(fields: [sshKeyId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  domains     Domain[]
  backups     Backup[]
  deployments Deployment[]
}

model Domain {
  id          String   @id @default(cuid())
  domain      String   @unique
  targetPort  Int
  sslEnabled  Boolean  @default(false)
  nginxConfig String?
  createdAt   DateTime @default(now())
  instanceId  String
  instance    Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Backup {
  id         String   @id @default(cuid())
  fileName   String
  filePath   String
  fileSize   Int
  createdAt  DateTime @default(now())
  instanceId String
  instance   Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model StorageBucket {
  id        String          @id @default(cuid())
  name      String
  createdAt DateTime        @default(now())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  objects   StorageObject[]

  @@unique([userId, name])
}

model StorageObject {
  id        String        @id @default(cuid())
  key       String
  size      Int
  mimeType  String?
  createdAt DateTime      @default(now())
  bucketId  String
  bucket    StorageBucket @relation(fields: [bucketId], references: [id], onDelete: Cascade)

  @@unique([bucketId, key])
}
